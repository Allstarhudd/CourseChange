<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.justusjoel.LoginController"
            style="-fx-background-color: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">

    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 40;">
            <!-- Card Container -->
            <VBox style="-fx-background-color: white; -fx-padding: 40; -fx-border-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);"
                  alignment="CENTER" spacing="25" prefWidth="350">

                <!-- Logo/Title -->
                <VBox alignment="CENTER" spacing="10">
                    <Label text="🎓📚" style="-fx-font-size: 48px;"/>
                    <Label text="Course Change System" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Login to your account" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                </VBox>

                <!-- Separator -->
                <Separator style="-fx-padding: 0;"/>

                <!-- Role Selection -->
                <VBox spacing="10">
                    <Label text="Select Your Role" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <HBox spacing="15">
                        <RadioButton fx:id="rbStudent" text="Student" selected="true"
                                    style="-fx-font-size: 12px; -fx-text-fill: #2c3e50;">
                            <toggleGroup>
                                <ToggleGroup fx:id="roleGroup"/>
                            </toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="rbAdmin" text="Admin"
                                    style="-fx-font-size: 12px; -fx-text-fill: #2c3e50;"
                                    toggleGroup="$roleGroup"/>
                    </HBox>
                </VBox>

                <!-- Username -->
                <VBox spacing="6">
                    <Label text="Username" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <TextField fx:id="txtUsername" promptText="Enter your username"
                              style="-fx-padding: 10; -fx-font-size: 12px; -fx-border-radius: 4; -fx-border-color: #ecf0f1; -fx-border-width: 2;"/>
                </VBox>

                <!-- Password -->
                <VBox spacing="6">
                    <Label text="Password" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <PasswordField fx:id="txtPassword" promptText="Enter your password"
                                  style="-fx-padding: 10; -fx-font-size: 12px; -fx-border-radius: 4; -fx-border-color: #ecf0f1; -fx-border-width: 2;"/>
                </VBox>

                <!-- Error Message -->
                <Label fx:id="lblError" style="-fx-text-fill: #e74c3c; -fx-font-size: 11px; -fx-text-alignment: center;"/>

                <!-- Login Button -->
                <Button text="🔓 Login" onAction="#handleLogin"
                        style="-fx-padding: 12 30; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-text-fill: white; -fx-cursor: hand; -fx-border-radius: 4;"
                        prefHeight="45" prefWidth="250"/>

                <!-- Demo Info -->
                <VBox style="-fx-background-color: #ecf0f1; -fx-padding: 12; -fx-border-radius: 4;" spacing="6">
                    <Label text="Demo Credentials:" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    <Label text="Student: student1 / pass123" style="-fx-font-size: 10px; -fx-text-fill: #34495e;"/>
                    <Label text="Admin: admin1 / admin123" style="-fx-font-size: 10px; -fx-text-fill: #34495e;"/>
                </VBox>

            </VBox>
        </VBox>
    </center>

</BorderPane>
